# ---------------------------
# 1. API KEYS
# ---------------------------
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
NEWS_API_KEY=YOUR_NEWS_API_KEY_HERE
YOUTUBE_STREAM_KEY=YOUR_YOUTUBE_STREAM_KEY_HERE

# ---------------------------
# 2. DATABASE (FIXED)
# ---------------------------
DB_HOST=postgres
DB_NAME=vartapravah
DB_USER=postgres
DB_PASS=password

# ✅ IMPORTANT (used by FastAPI / SQLAlchemy)
DATABASE_URL=postgresql://postgres:password@postgres:5432/vartapravah

# ---------------------------
# 3. REDIS (FIXED)
# ---------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---------------------------
# 4. TEMPORAL (VERY IMPORTANT)
# ---------------------------
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default

# ---------------------------
# 5. STREAMING SERVER (YOUR SETUP)
# ---------------------------
STREAM_URL=rtmp://YOUR_STREAM_SERVER/live/YOUR_STREAM_KEY

# Example:
# STREAM_URL=rtmp://80.225.209.104/live/vartapravah

# ---------------------------
# 6. INFRASTRUCTURE
# ---------------------------
HETZNER_NODE_URL=http://<hetzner-ip>:8000
ORACLE_NODE_IP=
USE_GPU=False

# ---------------------------
# 7. PATHS
# ---------------------------
ASSETS_DIR=/app/assets
OUTPUT_DIR=/app/output
LOG_DIR=/app/logs

# ---------------------------
# 8. OPTIONAL (STABILITY)
# ---------------------------
PYTHONUNBUFFERED=1