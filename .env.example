# --- Varta Pravah - Configuration Template ---

# 1. API KEYS (GET FROM OFFICIAL SOURCES)
# Get Groq key from console.groq.com
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Get NewsAPI key from newsapi.org
NEWS_API_KEY=YOUR_NEWS_API_KEY_HERE

# Get from your YouTube Live Dashboard
YOUTUBE_STREAM_KEY=YOUR_YOUTUBE_STREAM_KEY_HERE

# 2. DATABASE CONFIG
DB_HOST=vartapravah_postgres
DB_NAME=vartapravah
DB_USER=postgres
DB_PASS=password

# 3. REDIS CONFIG
REDIS_HOST=vartapravah_redis
REDIS_PORT=6379

# 4. INFRASTRUCTURE
# Set this to your primary server's public IP on the relay server
HETZNER_NODE_URL=http://localhost:8000
USE_GPU=False

# 5. LOGS & PATHS
ASSETS_DIR=/app/assets
OUTPUT_DIR=/app/output
LOG_DIR=/app/logs
